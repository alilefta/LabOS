// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

generator zod {
  provider = "prisma-zod-generator"
}

enum AuthUserRole {
  SYSTEM_USER
  LAB_USER
}

enum LabRole {
  OWNER
  MANAGER
  ADMIN
  STAFF
}

enum SuperUserRole {
  ADMIN
  MANAGER
  STAFF
}

enum CaseStatus {
  NEW
  ASSIGNED
  PROCESSING
  COMPLETED
  FAILED
  DELIVERED
  DRAFT
}

enum AssetFileType {
  IMAGE
  VIDEO
  SCANNERFILE
}

enum PricingStrategy {
  BULK
  PERTOOTH
  CUSTOM
}

enum JawType {
  UPPER
  LOWER
  OTHER // for maxillofacial 
}


// New 1
enum ClinicStatus {
  ACTIVE
  INACTIVE
  SUSPENDED  // e.g. overdue payments
}

// New 2
enum ClinicType {
  SOLO       // one dentist = the owner, Dentist record mirrors Clinic contact
  CLINIC     // multiple dentists
  HOSPITAL   // hospital dental department
  UNIVERSITY // teaching hospital
}
// New 3
enum PatientGender {
  MALE
  FEMALE
  OTHER
}

// New 4
enum SubscriptionTier {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

// 4. case
// 5. dentist
// 6. patient
// 7. case status - delivered typo
// 8. CasePricingPlan - effect clinic and product
// 9. SubscriptionTier
// 10. category, worktype, product
// 11. 



enum ToothPosition {
  // Upper Right Quadrant (1)
  UpperRightThirdMolar
  UpperRightSecondMolar
  UpperRightFirstMolar
  UpperRightSecondPremolar
  UpperRightFirstPremolar
  UpperRightCanine
  UpperRightLateralIncisor
  UpperRightCentralIncisor // Upper Left Quadrant (2)
  UpperLeftCentralIncisor
  UpperLeftLateralIncisor
  UpperLeftCanine
  UpperLeftFirstPremolar
  UpperLeftSecondPremolar
  UpperLeftFirstMolar
  UpperLeftSecondMolar
  UpperLeftThirdMolar // Lower Left Quadrant (3)
  LowerLeftThirdMolar
  LowerLeftSecondMolar
  LowerLeftFirstMolar
  LowerLeftSecondPremolar
  LowerLeftFirstPremolar
  LowerLeftCanine
  LowerLeftLateralIncisor
  LowerLeftCentralIncisor // Lower Right Quadrant (4)
  LowerRightCentralIncisor
  LowerRightLateralIncisor
  LowerRightCanine
  LowerRightFirstPremolar
  LowerRightSecondPremolar
  LowerRightFirstMolar
  LowerRightSecondMolar
  LowerRightThirdMolar
}

model Lab {
  id                  String                  @id @default(uuid())

  title               String
  slug                String?
  brandAvatarUrl      String?
  subtitle            String?

  labSubscriptionPlan LabSubscriptionPlan?
  users               LabUser[]

  clinics             Clinic[]
  cases               Case[]
  technicians         Technician[]
  salesReps           SalesRepresentative[]
  caseCategories      CaseCategory[]
  workTypes           WorkType[]
  products            Product[]
  caseWorkItems       CaseWorkItem[]
  selectedTeeth       SelectedTooth[]
  casePricingPlans    CasePricingPlan[]
  caseAssetFiles      CaseAssetFile[]

  patients            Patient[]
  dentists            Dentist[]

  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
}




model Clinic {
  id                  String                  @id @default(uuid())
  labId               String
  lab                 Lab                     @relation(fields: [labId], references: [id], onDelete: Cascade)


  // Basic Info
  name                String
  description         String?
  website             String?
  notes               String?   // internal lab notes about this clinic
  status              ClinicStatus            @default(ACTIVE)
      
  type                ClinicType              @default(CLINIC) // signals solo vs multi-dentis
      
  // Location       
  city                String
  zipcode             String?
  address1            String
  address2            String?
  

 // Primary Contact
  email               String
  phoneNumber         String

  // Billing Contact (optional, defaults to primary if null)
  billingEmail        String?
  billingPhoneNumber  String?
  taxNumber           String?  // for invoicing

   // Business Relationship
  discount            Decimal?                @db.Decimal(5, 2)  // % discount applied to all cases
  creditLimit         Decimal?                @db.Decimal(10, 2) // max outstanding balance allowed
  currentBalance      Decimal                 @default(0) @db.Decimal(10, 2) // outstanding amount owed

  cases               Case[]
  dentists            Dentist[]

  casePricingPlans    CasePricingPlan[]

  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  @@index([labId])
}

model Dentist {
  id                  String                  @id @default(uuid())
  clinicId            String
  clinic              Clinic                  @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  labId String
  lab   Lab    @relation(fields: [labId], references: [id], onDelete: Cascade)

  name                String
  email               String?
  phoneNumber         String?
  isOwner             Boolean                 @default(false) // for SOLO type, this dentist IS the clinic owner
  isDefault           Boolean                 @default(false)
  notes               String?

  cases               Case[]

  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  @@index([clinicId])
  @@index([labId])
}

model Case {
  id                  String  @id @default(uuid())
  patientId           String
  patient             Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  caseNumber          String // Per lab and should be auto-genertaed - // "LAB-001", "LAB-002" — generated in application logic

  labId               String
  lab                 Lab    @relation(fields: [labId], references: [id], onDelete: Cascade)

  salesRepsId         String?
  salesReps           SalesRepresentative? @relation(fields: [salesRepsId], references: [id], onDelete: SetNull)

  caseItems           CaseWorkItem[]

  caseCategoryId      String?  
  caseCategory        CaseCategory? @relation(fields: [caseCategoryId], references: [id], onDelete: SetNull)

  status              CaseStatus    @default(DRAFT)
  grandTotal          Decimal       @default(0)

  clinicId            String?
  clinic              Clinic?       @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  dentistId           String?       // which dentist within the clinic ordered this
  dentist             Dentist?      @relation(fields: [dentistId], references: [id], onDelete: SetNull)

  technicianId        String?
  Technician          Technician?   @relation(fields: [technicianId], references: [id], onDelete: SetNull)

  caseAssetFiles      CaseAssetFile[]
  deadline            DateTime
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([labId])
  @@index([technicianId])
  @@index([salesRepsId])
  @@index([clinicId])

  @@unique([labId, caseNumber])
}

model Patient {
  id          String  @id @default(uuid())
  name        String
  description String? // e.g. "allergic to metal"
  notes       String?
  age         Int?
  gender      PatientGender?

  // removed, if lab need direct patient creation, they need to create a clinic for themselves
  // city        String
  // zipcode     String?
  // address1    String
  // address2    String?

  // email       String?
  // phoneNumber String?

  cases  Case[]
  labId String
  lab   Lab    @relation(fields: [labId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([labId])
}

model CaseWorkItem {
  id        String   @id @default(uuid())
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  labId     String
  lab       Lab      @relation(fields: [labId], references: [id], onDelete: Cascade)

  dentalCaseId    String
  dentalCase   Case   @relation(fields: [dentalCaseId], references: [id], onDelete: Cascade)

  casePricingPlanId    String
  casePricingPlan      CasePricingPlan @relation(fields: [casePricingPlanId], references: [id], onDelete: Cascade)
  totalPrice           Decimal

  // In case of updating the related case pricing plan in future, we keep history of case pricing plan here as well
  pricingStrategy      PricingStrategy @default(BULK)

  // if pricing is "Custom"
  firstToothPrice               Decimal?
  additionalToothPrice          Decimal?
  teethCountToApplyBulkPrice    Decimal?


  // if pricing is "Bulk" or "custom" and bulk threshold applied
  bulkPrice                     Decimal?

  // if pricing is "Per Tooth"
  toothPrice                    Decimal? 

  jawType JawType @default(UPPER)


  workTypeId String?
  workType   WorkType? @relation(fields: [workTypeId], references: [id], onDelete: SetNull)

  selectedTeeth SelectedTooth[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([labId])
  @@index(dentalCaseId)
  @@index([productId])
  @@index([casePricingPlanId])
}

model CaseAssetFile {
  id     String @id @default(uuid())
  dentalCaseId String
  dentalCase   Case   @relation(fields: [dentalCaseId], references: [id], onDelete: Cascade)

  title         String?
  description   String?
  documentUrl   String
  assetFileType AssetFileType @default(IMAGE)
  labId         String
  lab           Lab           @relation(fields: [labId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([labId])
  @@index([dentalCaseId])
}

model CaseCategory {
  id          String @id @default(uuid())
  name        String
  description String?
  imageUrl    String?

  isActive Boolean @default(true)

  workTypes WorkType[]
  cases     Case[]

  labId String
  lab   Lab    @relation(fields: [labId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([labId])
}

model WorkType {
  id          String @id @default(uuid())
  name        String
  description String?
  imageUrl    String?

  products    Product[]
  labId       String
  lab       Lab       @relation(fields: [labId], references: [id], onDelete: Cascade)

  requireTeethSelection Boolean @default(false)

  caseWorkItems   CaseWorkItem[]

  caseCategoryId String
  caseCategory   CaseCategory @relation(fields: [caseCategoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([labId])
  @@index([caseCategoryId])
}

model Product {
  id                          String @id @default(uuid())
  name                        String
  description                 String?
  imageUrl                    String?
            
  caseWorkItems               CaseWorkItem[]

  labId                       String
  lab                         Lab    @relation(fields: [labId], references: [id], onDelete: Cascade)

  workTypeId                  String
  workType                    WorkType @relation(fields: [workTypeId], references: [id], onDelete: Cascade)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  casePricingPlans            CasePricingPlan[]

  @@index([labId])
  @@index([workTypeId])
}

model CasePricingPlan {
  id    String @id @default(uuid())
  labId String
  lab   Lab    @relation(fields: [labId], references: [id], onDelete: Cascade)

  name      String
  isDefault Boolean @default(false)

  pricingStrategy      PricingStrategy @default(BULK)
  


  // if pricing is "Custom"
  firstToothPrice               Decimal?
  additionalToothPrice          Decimal?
  teethCountToApplyBulkPrice    Decimal?


  // if pricing is "Bulk" or "custom" and bulk threshold applied
  bulkPrice                     Decimal?

  // if pricing is "Per Tooth"
  toothPrice                    Decimal? 


  productId String?   // if pricing is per-product
  product   Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)



  clinicId  String?   // if pricing is per-clinic (custom deals)
  clinic    Clinic?   @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  caseWorkItem CaseWorkItem[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([labId])
}

model SelectedTooth {
  id             String        @id @default(uuid())
  toothPosition  ToothPosition
  caseWorkItemId String
  caseWorkItem   CaseWorkItem  @relation(fields: [caseWorkItemId], references: [id], onDelete: Cascade)

  labId String
  lab   Lab    @relation(fields: [labId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([labId])
  @@index([caseWorkItemId])
}


model Technician {
  id        String  @id @default(uuid())
  firstName String
  lastName  String
  city      String
  zipcode   String?
  address1  String
  address2  String?

  labId String
  lab   Lab    @relation(fields: [labId], references: [id], onDelete: Cascade)

  email       String
  phoneNumber String

  avatarUrl String

  cases Case[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([labId])
}

model SalesRepresentative {
  id        String  @id @default(uuid())
  firstName String
  lastName  String
  city      String
  zipcode   String?
  address1  String
  address2  String?

  labId String
  lab   Lab    @relation(fields: [labId], references: [id], onDelete: Cascade)

  email       String
  phoneNumber String

  avatarUrl String

  cases Case[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([labId])
}
model LabSubscriptionPlan {
  id                            String @id @default(uuid())
  labId                         String @unique
  lab                           Lab    @relation(fields: [labId], references: [id], onDelete: Cascade)

  // Idk what the pricing model should be 
  tier                          SubscriptionTier @default(FREE)
  maxMembers                    Int              @default(3)
  maxCasesMonth                 Int              @default(50)
  stripeCustomerId              String?
  stripeSubscriptionId          String?
  stripePriceId                 String?

  //discountCode          

  subscriptionNextRenewal       DateTime?
  isCancelled                   Boolean   @default(false)
  cancellationDate              DateTime?
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt

  //@@index([labId])  // this can be removed because @unqiue on labId automatically creates an index

}

model LabUser {
  id        String  @id @default(uuid())
  name      String
  city      String
  zipcode   String?
  address1  String
  address2  String?
  avatarUrl String

  secondaryEmail String?
  phoneNumber    String
  role           LabRole @default(OWNER)

  authUserId String   @unique
  authUser   AuthUser @relation(fields: [authUserId], references: [id], onDelete: Cascade)

  labId String
  lab   Lab    @relation(fields: [labId], references: [id], onDelete: Cascade)

  isActive Boolean @default(true)

  lastTimeActive DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([labId])
}

model SuperUser {
  id        String  @id @default(uuid())
  name      String
  city      String
  zipcode   String?
  address1  String
  address2  String?
  avatarUrl String

  secondaryEmail String?
  phoneNumber    String
  role           SuperUserRole @default(ADMIN)

  authUserId String   @unique
  authUser   AuthUser @relation(fields: [authUserId], references: [id], onDelete: Cascade)

  isActive Boolean @default(true)

  lastTimeActive DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model AuthUser {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          AuthUserRole    @default(LAB_USER)
  // labId         String?
  sessions      Session[]
  accounts      Account[]

  labUser   LabUser?
  superUser SuperUser?

  labId String?

  @@unique([email])
  @@map("AuthUser")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  authuser  AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  // labId String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  authuser              AuthUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
