model LabSubscriptionPlan {
  id    String @id @default(uuid())
  labId String @unique
  lab   Lab    @relation(fields: [labId], references: [id], onDelete: Cascade)

  // Idk what the pricing model should be 
  tier                 SubscriptionTier @default(FREE)
  maxMembers           Int              @default(3)
  maxCasesMonth        Int              @default(50)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePriceId        String?

  //discountCode          

  subscriptionNextRenewal DateTime?
  isCancelled             Boolean   @default(false)
  cancellationDate        DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  //@@index([labId])  // this can be removed because @unqiue on labId automatically creates an index
}

model LabUser {
  id        String  @id @default(uuid())
  name      String
  city      String
  zipcode   String?
  address1  String
  address2  String?
  avatarUrl String

  secondaryEmail String?
  phoneNumber    String
  role           LabRole @default(OWNER)

  authUserId String   @unique
  authUser   AuthUser @relation(fields: [authUserId], references: [id], onDelete: Cascade)

  labId String
  lab   Lab    @relation(fields: [labId], references: [id], onDelete: Cascade)

  isActive Boolean @default(true)

  lastTimeActive DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([labId])
}

model SuperUser {
  id        String  @id @default(uuid())
  name      String
  city      String
  zipcode   String?
  address1  String
  address2  String?
  avatarUrl String

  secondaryEmail String?
  phoneNumber    String
  role           SuperUserRole @default(ADMIN)

  authUserId String   @unique
  authUser   AuthUser @relation(fields: [authUserId], references: [id], onDelete: Cascade)

  isActive Boolean @default(true)

  lastTimeActive DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model AuthUser {
  id            String       @id
  name          String
  email         String
  emailVerified Boolean      @default(false)
  image         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  role          AuthUserRole @default(LAB_USER)
  // labId         String?
  sessions      Session[]
  accounts      Account[]

  labUser   LabUser?
  superUser SuperUser?

  labId String?

  @@unique([email])
  @@map("AuthUser")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  authuser  AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  // labId String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  authuser              AuthUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
